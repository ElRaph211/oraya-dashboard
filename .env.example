# ============================================================
# Oraya Dashboard — Variables d'environnement
# ============================================================
# Copier ce fichier en `.env` et remplir avec vos valeurs.

# --- Supabase ----------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...  # anon key
SUPABASE_SERVICE_ROLE_KEY=eyJ... # service_role key (SECRET)

# Variables côté client (exposées au navigateur via Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=your-project

# --- IA Anthropic ------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Emails (Resend) ---------------------------------------------
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...  # signing secret pour vérifier les webhooks

# --- Compte admin (bootstrap automatique au login) ---------------
ADMIN_EMAIL=raphael@orayasystem.fr
ADMIN_PASSWORD=changeme

# --- Cron (production uniquement) --------------------------------
# Token utilisé pour authentifier les endpoints /api/cron/*
CRON_SECRET=your-random-cron-secret

# --- Tests e2e Playwright (optionnel) ----------------------------
E2E_CLIENT_EMAIL=contact@example.com
E2E_CLIENT_PASSWORD=

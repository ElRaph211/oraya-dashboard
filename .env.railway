# ============================================================
# .env.railway — Template variables Railway pour Oraya Dashboard
# ============================================================
# Ce fichier est un TEMPLATE — il liste les variables à configurer
# dans Railway Dashboard → Project → Service → Variables.
# Ne PAS mettre les vraies valeurs ici (ce fichier est commité dans le repo).

# --- Supabase ---------------------------------------------------------
# Production projet jmaathyfyfifpbxclhab
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Variables côté client (Vite remplace au build)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- IA Anthropic -----------------------------------------------------
ANTHROPIC_API_KEY=

# --- Emails Resend ----------------------------------------------------
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# --- Bootstrap admin --------------------------------------------------
ADMIN_EMAIL=raphael@orayasystem.fr
ADMIN_PASSWORD=

# --- Cron auth (header Bearer ${CRON_SECRET}) -------------------------
CRON_SECRET=

# --- Runtime ----------------------------------------------------------
NODE_ENV=production
# PORT et HOSTNAME sont injectés automatiquement par Railway, ne pas configurer
